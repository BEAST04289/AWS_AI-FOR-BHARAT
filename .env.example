# ==================== AWS Credentials ====================
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=ap-south-1

# ==================== Bedrock Configuration ====================
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# ==================== AWS Resources ====================
DYNAMODB_TABLE=shield-fingerprint
S3_BUCKET=shield-temp-upload

# ==================== App Configuration ====================
FLASK_ENV=production
DEMO_MODE=false
PORT=5000

# ==================== Security ====================
# API key for programmatic access (leave empty for open mode)
SHIELD_API_KEY=
# Admin key for /api/stats endpoint (leave empty for open mode)
SHIELD_ADMIN_KEY=
# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# ==================== Rate Limiting ====================
MAX_REQUESTS_PER_IP_PER_DAY=50
MAX_BURST_PER_MINUTE=10
MAX_FILE_SIZE_MB=5
MAX_TEXT_LENGTH=5000
